# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Instagram Configuration (Optional)
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password
INSTAGRAM_ENABLED=false

# AI Analysis Configuration
AI_ENABLED=true
# AI_PROVIDER options: 'openrouter' (default), 'deepseek', 'openai', 'gemini'
AI_PROVIDER=openrouter

# ── OpenRouter (recommended — switch models without changing code) ───────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Model string format: "provider/model-name"  (see https://openrouter.ai/models)
OPENROUTER_MODEL=deepseek/deepseek-chat
# Popular alternatives:
#   deepseek/deepseek-chat          — fast & cheap (same as direct DeepSeek)
#   anthropic/claude-3.5-sonnet     — highest quality
#   openai/gpt-4o                   — OpenAI flagship
#   google/gemini-2.0-flash-exp:free — free tier
#   meta-llama/llama-3.3-70b-instruct:free — free tier

# ── DeepSeek (direct) ────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# ── Gemini AI (Google) ───────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Exchange Configuration
EXCHANGE=binance

# Continuous Monitor Configuration (for continuous-monitor.js)
MONITOR_PAIRS=BTC/USDT,ETH/USDT
CHECK_INTERVAL=60000
MIN_CONFIDENCE=70
COOLDOWN_MINUTES=60
# EXCHANGE_API_KEY=optional_for_private_endpoints
# EXCHANGE_API_SECRET=optional_for_private_endpoints

# Bot Configuration
INSTRUCTION_FILE=instructions/default.md
DRY_RUN=false
LOG_LEVEL=info
