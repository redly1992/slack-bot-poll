# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Instagram Configuration (Optional)
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password
INSTAGRAM_ENABLED=false

# AI Analysis Configuration
AI_ENABLED=true
AI_PROVIDER=deepseek
# AI_PROVIDER options: 'deepseek', 'gemini', or 'openai'

# DeepSeek AI - Cost-effective and powerful!
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
# DeepSeek models: deepseek-chat (main model), deepseek-reasoner (for complex reasoning)

# Gemini AI (Google) - FREE tier available!
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
# Gemini models: gemini-1.5-flash (fast, free), gemini-1.5-pro (advanced), gemini-2.0-flash-exp

# OpenAI (Alternative)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
# OpenAI models: gpt-4o-mini (cheap), gpt-4o, gpt-4-turbo, gpt-3.5-turbo

# Exchange Configuration
EXCHANGE=binance
# EXCHANGE_API_KEY=optional_for_private_endpoints
# EXCHANGE_API_SECRET=optional_for_private_endpoints

# Bot Configuration
INSTRUCTION_FILE=instructions/default.md
DRY_RUN=false
LOG_LEVEL=info
